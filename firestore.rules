rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /typeracer_scores/{scoreId} {
      allow read: if true;
      allow create: if isValidScore(request.resource.data);
    }
  }
}

function isValidScore(data) {
  return data.keys().hasAll(['name', 'wpm', 'accuracy', 'racer', 'timestamp'])
    && data.keys().size() == 5
    && data.name is string
    && data.name.size() > 0
    && data.name.size() <= 25
    && data.wpm is number
    && data.wpm >= 0
    && data.wpm <= 300
    && data.accuracy is number
    && data.accuracy >= 0
    && data.accuracy <= 100
    && data.racer is string
    && data.racer.size() <= 25;
}
